# StudentVault — Environment Variables
# Copy this file to .env and fill in your values

PORT=5001
MONGO_URI=mongodb://localhost:27017/studentvault

# ── Firebase Configuration (optional — enables Firestore dual-write sync) ─
# 1. Create a Firebase project at https://console.firebase.google.com
# 2. Enable Firestore Database in the project
# 3. Project Settings → Service Accounts → Generate new private key
# 4. Copy the values from the downloaded JSON into the vars below

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
